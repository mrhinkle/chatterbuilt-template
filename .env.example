# Resend (https://resend.com) — contact form email delivery
# Without RESEND_API_KEY the form still succeeds locally and logs the submission.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Admin panel (/admin) — simple password gate (session cookie)
# Without ADMIN_PASSWORD the /admin page explains how to enable it.
ADMIN_PASSWORD=

# Optional: fine-grained GitHub token so /admin can commit
# content/integrations.json and content/kb.json via the GitHub API.
# Needs Contents: Read and Write on this repo only.
# Without GITHUB_TOKEN, Save still works — the panel shows the exact JSON
# to paste or hand to your AI (same graceful pattern as the contact form).
GITHUB_TOKEN=
# owner/repo — required when GITHUB_TOKEN is set outside Vercel
GITHUB_REPO=
# Branch to commit to (default: main, or VERCEL_GIT_COMMIT_REF)
GITHUB_BRANCH=main

# Optional AI-enhanced chatbot mode (OFF by default in the widget UI).
# Free keyword mode needs no keys and costs $0.
# Setting a key enables an optional toggle that calls your provider — that
# usage is billed to YOU (BYO key). Prefer free keyword mode for most sites.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
